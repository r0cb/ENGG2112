# Raw data (regenerable from APIs by Notebook 00 — do not commit)
data/raw/*
!data/raw/.gitkeep

# Processed data — commit small canonical CSVs (master_stacked, master_counties)
# and selected_features.json (consumed by downstream notebooks); ignore the rest
data/processed/*
!data/processed/.gitkeep
!data/processed/master_stacked.csv
!data/processed/master_counties.csv
!data/processed/selected_features.json

# Archived data and notebooks (kept locally, not committed)
_archive/

# Model artifacts: track JSON metrics for transparency, ignore .pkl binaries
# (notebooks regenerate the .pkl when run)
models/*.pkl

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.env
venv/
.venv/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.cursor/

# Local / personal
.Rhistory
.claude/
